# Epiphaneia 环境配置
# 复制为 .env 并填写实际值
#
# 配置分层：
#   .env 文件 = 基础设施密钥（DB 密码、加密密钥、LLM API Key）
#   Web UI Settings 页面 = 应用级配置（数据源URL、应用注册、LLM 模型选择）
#   两者均写入的（如 LLM API Key）：env 优先，Web UI 可覆盖（加密存 DB）

# ── 必需 ──────────────────────────────────────────

# 数据库用户名
DB_USER=epiphaneia

# 数据库密码（修改为你自己的强密码）
DB_PASSWORD=change-me-to-a-random-password

# AES-256-GCM 加密密钥 — 64 字符 hex（256 bit）
# 生成命令：openssl rand -hex 32
# 不能为空！应用启动时强制校验
EPIPHANEIA_ENCRYPTION_KEY=

# ── 可选 ──────────────────────────────────────────

# LLM API Key — 可选，也可以在 Web UI Settings 页面配置
# Spring AI 自动读取以下环境变量，无需额外代码
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# 使用本地 Ollama 则无需 API Key

# 应用端口（默认 8080）
# SERVER_PORT=8080

# Spring Profile（dev/prod，默认 dev）
# SPRING_PROFILES_ACTIVE=dev
