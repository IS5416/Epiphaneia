# Epiphaneia 环境配置
# 复制为 .env 并填写实际值: cp .env.example .env
#
# 配置分层:
#   .env = 基础设施密钥（DB密码、加密密钥）
#   Web UI Settings 页面 = 数据源URL、LLM模型选择、API Key
#   application-prod.yml = 生产环境安全加固

# ── 必需 ──────────────────────────────────────────

# 数据库用户名
DB_USER=epiphaneia

# 数据库密码 — 修改为你自己的强密码
DB_PASSWORD=change-me

# AES-256-GCM 加密密钥 — 64字符 hex (256 bit)
# 生成命令: openssl rand -hex 32
EPIPHANEIA_ENCRYPTION_KEY=

# ── 可选 ──────────────────────────────────────────

# LLM API Key — Spring AI 自动读取，或在 Web UI Settings 页面配置后加密存 DB
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...

# 服务端口 (默认 8080)
# SERVER_PORT=8080

# Spring Profile (默认空=base, 生产用 prod)
# SPRING_PROFILES_ACTIVE=prod

# 日志级别 (默认 INFO)
# LOG_LEVEL=DEBUG

# Cookie 安全 (生产环境由 application-prod.yml 自动设为 secure+strict)
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict
